# =============================================
# DevGuard AI - Environment Variables
# Copy this file to .env and fill in the values
# =============================================

# --- PostgreSQL ---
POSTGRES_USER=devguard
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=devguard_db

# --- Backend ---
NODE_ENV=development
PORT=3001
DATABASE_URL=postgresql://devguard:change_me_in_production@localhost:5432/devguard_db
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
JWT_SECRET=change_me_super_secret_jwt_key_32chars_min

# --- Firebase Admin SDK ---
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY\n-----END PRIVATE KEY-----\n"

# --- OpenAI ---
OPENAI_API_KEY=sk-...

# --- Mercado Pago ---
MERCADOPAGO_ACCESS_TOKEN=your_mp_access_token
MERCADOPAGO_WEBHOOK_SECRET=your_mp_webhook_secret

# --- Frontend ---
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_FIREBASE_API_KEY=your-firebase-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-firebase-project-id
NEXT_PUBLIC_FIREBASE_APP_ID=your-app-id

# --- Pricing (BRL cents) ---
SINGLE_SCAN_PRICE=990
SUBSCRIPTION_PRICE=3990

# --- Admin ---
ADMIN_EMAILS=seu-email@gmail.com
